{
  "name": "stoicheia",
  "private": true,
  "version": "1.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:budget": "node scripts/check-bundle-budget.mjs",
    "build:check": "npm run build && npm run build:budget",
    "perf:parse": "cargo test --release --manifest-path src-tauri/Cargo.toml parser::tests::benchmarks_large_documents -- --ignored --nocapture",
    "perf:render": "STOICHEIA_RENDER_BENCHMARK=1 vitest --run src/renderers/FastSvgRenderer.test.tsx -t \"benchmarks large instant renderer scenes\" --reporter verbose",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "tauri:build:linux": "NO_STRIP=1 tauri build --bundles deb,rpm,appimage",
    "tauri:build:appimage": "NO_STRIP=1 tauri build --bundles appimage"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  }
}
